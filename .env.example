# Xandus Hive UI — Environment Variables
# Copy this file to .env and fill in your values.

# ── OpenClaw Gateway ──────────────────────────────────────────
# WebSocket URL of your OpenClaw gateway (default: ws://localhost:18789)
VITE_GATEWAY_URL=ws://localhost:18789

# Gateway authentication token (must match your OPENCLAW_GATEWAY_TOKEN)
VITE_GATEWAY_TOKEN=

# ── Supabase (optional) ──────────────────────────────────────
# Required only for business modules (workspace, finance, etc.)
# The Hive agent-control modules work without Supabase.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
